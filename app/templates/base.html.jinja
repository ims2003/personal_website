<!DOCTYPE html>
<html>
<head>
    <title>{% block title %}{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <style type="text/tailwindcss">
        @layer components {
            .nav-button {
                @apply border-2 border-emerald-900 bg-stone-50 p-2 rounded text-emerald-900 transition-colors hover:bg-emerald-900 hover:text-white;
            }
            .nav-button-active {
                @apply bg-emerald-900 text-white;
            }
            h2 {
                @apply text-3xl font-semibold text-stone-800 mb-4 border-b-2 border-stone-300 pb-2;
            }
            p {
                @apply mb-6 leading-relaxed;
            }
            a {
                @apply italic underline decoration-stone-400 decoration-2 underline-offset-4 transition-all hover:text-emerald-900 hover:decoration-emerald-900
            }
            nav {
                @apply mb-1 leading-relaxed;
            }
            hr {
                @apply border-stone-50
            }
            img {
                @apply border-2 border-stone-900 mx-auto shadow-lg object-cover mb-2 hover:border-emerald-900
            }
        }
    </style>
</head>
<body class="bg-stone-50 font-serif">
    <div class="flex justify-center py-4">
        <nav class="flex gap-6">
            <a href="/"><button class="nav-button {% if request.path == '/' %} nav-button-active {% endif %}">Home</button></a>
            <a href="/about"><button class="nav-button {% if request.path == '/about' %} nav-button-active {% endif %}">About</button></a>
            <a href="/resume"><button class="nav-button {% if request.path == '/resume' %} nav-button-active {% endif %}">Resume</button></a>
            <a href="/projects"><button class="nav-button {% if request.path == '/projects' %} nav-button-active {% endif %}">Projects</button></a>
            <a href="/pursuits"><button class="nav-button {% if request.path == '/pursuits' %} nav-button-active {% endif %}">Pursuits</button></a>
        </nav>
    </div>
    <main class="max-w-4xl mx-auto px-5 pb-20">
        {% block content %}
        <!-- Content goes here -->
        {% endblock %}
    </main>
</body>
</html>